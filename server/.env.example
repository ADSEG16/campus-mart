PORT=5000

MONGO_URI=xxxxxxxxxxxxxxxx

CLOUDINARY_NAME=campusmart
CLOUDINARY_API_KEY=xxxxxxxxxxxx
CLOUDINARY_SECRET=xxxxxxxxxx

JWT_SECRET=your_secret_key_here

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_account@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Campus Mart <your_account@gmail.com>
# Optional SMTP tuning
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_REJECT_UNAUTHORIZED=true
APP_BASE_URL=http://localhost:5000
CLIENT_BASE_URL=http://localhost:5173

# Base64-encoded 32-byte key for message encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MESSAGE_ENCRYPTION_KEY=replace_with_base64_32_byte_key